rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permissive rules for industrial ERP application
    match /users/{userId} {
      allow read, write: if true;
    }
    match /machines/{machineId} {
      allow read, write: if true;
    }
    match /parts/{partId} {
      allow read, write: if true;
    }
    match /repair_requests/{requestId} {
      allow read, write: if true;
    }
    match /work_orders/{orderId} {
      allow read, write: if true;
    }
    match /pm_plans/{planId} {
      allow read, write: if true;
    }
    match /pm_schedules/{schedId} {
      allow read, write: if true;
    }
    match /spare_transactions/{transId} {
      allow read, write: if true;
    }
    match /audit_logs/{logId} {
      allow read, write: if true;
    }
    match /notifications/{notifyId} {
      allow read, write: if true;
    }
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
